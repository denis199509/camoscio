# Copia questo file in ".env" (stesso nome, senza .example) e riempi i valori reali.
# Il file ".env" non viene mai caricato su GitHub (e' escluso in .gitignore).

# Porta su cui parte il server in locale
PORT=3000

# "development" in locale, "production" quando gira su Render (Fase E)
NODE_ENV=development

# Stringa segreta per firmare i cookie di sessione di login (Fase C). Deve essere lunga e casuale.
SESSION_SECRET=sostituisci-con-una-stringa-lunga-e-casuale

# Stringa di connessione MongoDB Atlas, del tipo mongodb+srv://... (arriva nella Fase B, per ora lascia vuoto)
MONGODB_URI=
